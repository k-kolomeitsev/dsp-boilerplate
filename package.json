{
  "name": "dsp-boilerplate",
  "version": "0.0.0",
  "engines": {
    "node": ">= 22"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "~9.17",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/eslint__js": "~8.42",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "~20",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/parser": "~8.19",
    "@vitest/coverage-v8": "~2.1",
    "@vitest/eslint-plugin": "~1.1",
    "eslint": "~9.17",
    "eslint-config-prettier": "~9.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "~15.14",
    "jest": "^30.0.0",
    "prettier": "~3.4",
    "rimraf": "~6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-api-utils": "~2.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "~10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7",
    "typescript-eslint": "~8.19",
    "vitest": "~2.1"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "frontend:install": "yarn --cwd frontend install",
    "frontend:dev": "yarn --cwd frontend dev",
    "frontend:build": "yarn --cwd frontend build",
    "frontend:preview": "yarn --cwd frontend preview",
    "frontend:lint": "yarn --cwd frontend lint",
    "migration:generate": "ts-node --project ./tsconfig.json -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:generate -p -d src/typeorm-cli-datasource.ts",
    "migration:create": "ts-node --project ./tsconfig.json -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:create",
    "migration:run": "ts-node --project ./tsconfig.json -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:run -d src/typeorm-cli-datasource.ts -t=each",
    "migration:revert": "ts-node --project ./tsconfig.json -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js migration:revert -d src/typeorm-cli-datasource.ts"
  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.10",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "aws-sdk": "^2.1693.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ioredis": "^5.8.2",
    "moment": "^2.30.1",
    "nats": "^2.29.3",
    "nest-aws-sdk": "^3.1.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tslib": "~2.8",
    "typeorm": "^0.3.20",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "volta": {
    "node": "22.12.0"
  }
}
